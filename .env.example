# Copy this file to ".env.local" and fill in your own values.
# .env.local is gitignored, so your real secrets never get committed.

# Password for the /admin dashboard.
ADMIN_PASSWORD=choose-a-strong-password
# A long random string used to sign the admin login cookie.
ADMIN_SECRET=any-long-random-string
# Optional 2FA for /admin. Use a base32 TOTP secret from Google Authenticator,
# 1Password, Authy, or another authenticator app. When set, login requires both
# ADMIN_PASSWORD and a 6 digit code.
ADMIN_TOTP_SECRET=

# Supabase (Behind the Team roster). Project Settings -> API in Supabase.
# Leave blank to fall back to the bundled roster content.
# Add the SAME values in Vercel -> Project -> Settings -> Environment Variables.
# Public, sent to the browser (reads only):
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# SECRET, server only, never exposed. Used by /api/admin/members to save.
# Keep this private; rotate it if it ever leaks.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Canonical site origin for SEO/OG/structured data. Set to your custom domain
# once connected (e.g. https://niightmareesport.com).
NEXT_PUBLIC_SITE_URL=https://niightmareesport.com

# Web Push for admin paid-order alerts (fires when a buyer declares a transfer).
# Generate ONE keypair and reuse it everywhere:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# Public key — also sent to the browser to subscribe (NEXT_PUBLIC_ on purpose):
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
# Private key — SECRET, server only, never exposed:
VAPID_PRIVATE_KEY=your-vapid-private-key
# Contact subject for push services (a mailto: address):
VAPID_SUBJECT=mailto:admin@niightmareesport.com

# Optional: send shop paid-order email notifications through the site
# Formspree endpoint. Leave false so fake slips / high order volume do not
# consume Formspree's free monthly submissions; Admin Web Push + /admin Orders
# remain the primary alert system.
SHOP_ORDER_EMAIL_NOTIFICATIONS=false
